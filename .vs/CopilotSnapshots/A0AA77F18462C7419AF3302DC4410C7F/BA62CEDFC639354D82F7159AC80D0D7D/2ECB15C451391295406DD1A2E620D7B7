    public static class ErrorAnalysisData
    {
        private static List<ErrorAnalysis> _errors;

        public static List<ErrorAnalysis> GetAll()
        {
            if (_errors == null)
            {
                _errors = new List<ErrorAnalysis>();
            }
            return _errors;
        }

        public static ErrorAnalysis GetById(int id)
        {
            return GetAll().Find(e => e.Id == id);
        }

        public static void Add(ErrorAnalysis error)
        {
            var list = GetAll();
            error.Id = list.Count > 0 ? list.Max(e => e.Id) + 1 : 1;
            error.UpdatedDate = DateTime.Now;
            list.Insert(0, error);
        }

        public static void Update(ErrorAnalysis error)
        {
            var list = GetAll();
            var index = list.FindIndex(e => e.Id == error.Id);
            if (index >= 0)
            {
                error.UpdatedDate = DateTime.Now;
                list[index] = error;
            }
        }

        public static void Delete(int id)
        {
            var list = GetAll();
            list.RemoveAll(e => e.Id == id);
        }
    }
