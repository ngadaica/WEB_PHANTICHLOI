@model WEB_PHANTICHLOI.Models.ErrorAnalysis
@{
    ViewBag.Title = "Thêm mới lỗi 追加";
    Layout = "~/Views/Shared/_ISSLayout.cshtml";
}

<style>
    .ea-create-page {
        max-width: 1280px;
        margin: 0 auto;
    }

    .ea-page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 20px;
    }

    .ea-page-title {
        margin: 0;
        font-size: 24px;
        font-weight: 700;
        color: #1f2937;
    }

    .ea-page-subtitle {
        margin-top: 4px;
        color: #6b7280;
        font-size: 13px;
    }

    .ea-create-page .iss-card {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
        margin-bottom: 18px;
    }

    .ea-create-page .iss-card-header,
    .ea-create-page .iss-card-header.green,
    .ea-create-page .iss-card-header.orange,
    .ea-create-page .iss-card-header.purple,
    .ea-create-page .iss-card-header.red {
        background: #ffffff;
        color: #111827;
        border-bottom: 1px solid #e5e7eb;
        padding: 14px 18px;
        font-size: 15px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .ea-create-page .iss-card-body {
        padding: 18px;
    }

    .ea-create-page .iss-form .form-group {
        margin-bottom: 14px;
    }

    .ea-create-page .iss-form label {
        font-size: 12px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
    }

        .ea-create-page .iss-form label .label-jp {
            color: #9ca3af;
            font-weight: 400;
        }

    .ea-create-page .iss-form .form-control {
        max-width: 100%;
        min-height: 38px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 8px 12px;
        font-size: 13px;
        background: #ffffff;
        box-shadow: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

        .ea-create-page .iss-form .form-control:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
            outline: none;
            background: #ffffff;
        }

    .ea-create-page .iss-form textarea.form-control {
        min-height: 96px;
        resize: vertical;
        background: #ffffff;
    }

    .ea-create-page .iss-form .form-control-readonly {
        background: #f9fafb;
        color: #6b7280;
    }

    .ea-section-panel {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 10px;
        padding: 14px;
        margin-bottom: 12px;
    }

    .ea-inline-note {
        font-size: 12px;
        color: #6b7280;
        margin-top: 6px;
    }

    .ea-create-page .manual-input-badge {
        background: #eef2ff;
        color: #4338ca;
        padding: 2px 8px;
        border-radius: 999px;
        font-size: 10px;
        font-weight: 600;
        margin-left: 6px;
    }

    .ea-create-page .auto-fill-hint,
    .ea-create-page .formula-display,
    .ea-create-page .note-bubble {
        background: #f9fafb;
        border: 1px solid #e5e7eb;
        color: #4b5563;
        border-radius: 8px;
        padding: 8px 12px;
        font-size: 12px;
    }

        .ea-create-page .note-bubble::before {
            display: none;
        }

    .ea-create-page .btn-group-iss {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        justify-content: flex-end;
        margin-top: 24px;
        padding-top: 18px;
        border-top: 1px solid #e5e7eb;
    }

    .ea-create-page .btn-iss {
        min-height: 40px;
        padding: 10px 18px;
        border-radius: 8px;
        box-shadow: none;
        text-decoration: none;
    }

    .ea-create-page .btn-iss-primary {
        background: #2563eb;
        color: #ffffff;
    }

        .ea-create-page .btn-iss-primary:hover {
            background: #1d4ed8;
        }

    .ea-create-page .btn-iss-warning,
    .ea-create-page .btn-iss-secondary {
        background: #ffffff;
        color: #374151;
        border: 1px solid #d1d5db;
    }

        .ea-create-page .btn-iss-warning:hover,
        .ea-create-page .btn-iss-secondary:hover {
            background: #f9fafb;
        }

    .ea-file-input {
        background: #ffffff;
        padding: 6px;
    }

    @@media (max-width: 768px) {
        .ea-page-header {
            flex-direction: column;
            align-items: stretch;
        }

        .ea-create-page .btn-group-iss {
            justify-content: stretch;
        }

            .ea-create-page .btn-group-iss .btn-iss {
                width: 100%;
                justify-content: center;
            }
    }
</style>

<div class="ea-create-page">
    <div class="ea-page-header">
        <div>
            <h1 class="ea-page-title">Thêm mới lỗi</h1>
            <div class="ea-page-subtitle">Nhập thông tin phân tích lỗi theo bố cục rõ ràng, chuyên nghiệp và dễ theo dõi.</div>
        </div>
        <a href="@Url.Action("Index")" class="btn-iss btn-iss-secondary">
            Quay lại danh sách
        </a>
    </div>

    @using (Html.BeginForm("Create", "ErrorAnalysis", FormMethod.Post, new { enctype = "multipart/form-data", @class = "iss-form" }))
    {
        @Html.AntiForgeryToken()

        <div class="iss-card">
            <div class="iss-card-header">
                Thông tin cơ bản <span style="font-weight:400;">基本情報</span>
            </div>
            <div class="iss-card-body">
                <div class="row">
                    <div class="col-md-12 form-group">
                        <label>Hiện tượng <span class="label-jp">現象</span> <span class="manual-input-badge">Nhập tay</span></label>
                        @Html.TextBoxFor(m => m.Phenomenon, new { @class = "form-control", placeholder = "Nhập hiện tượng lỗi..." })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 form-group">
                        <label>Nội dung vấn đề <span class="label-jp">問題内容</span></label>
                        @Html.TextAreaFor(m => m.ProblemContent, new { @class = "form-control", rows = 3, placeholder = "Mô tả chi tiết vấn đề..." })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3 form-group">
                        <label>Chủng loại</label>
                        @Html.TextBoxFor(m => m.Category, new { @class = "form-control", placeholder = "VD: FCL, ELLs..." })
                    </div>
                    <div class="col-md-3 form-group">
                        <label>Model</label>
                        @Html.TextBoxFor(m => m.Model, new { @class = "form-control", placeholder = "Nhập model..." })
                    </div>
                    <div class="col-md-3 form-group">
                        <label>Dừng xuất xưởng <span class="label-jp">出荷停止</span></label>
                        @Html.DropDownListFor(m => m.ShipmentStop, (List<SelectListItem>)ViewBag.ShipmentStopOptions, new { @class = "form-control" })
                    </div>
                    <div class="col-md-3 form-group">
                        <label>Người điều tra <span class="label-jp">調査担当</span></label>
                        @Html.TextBoxFor(m => m.Investigator, new { @class = "form-control", placeholder = "Tên người điều tra..." })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3 form-group">
                        <label>Phân loại giai đoạn <span class="label-jp">ステージ種別</span></label>
                        @Html.DropDownListFor(m => m.StageClassification, (List<SelectListItem>)ViewBag.StageOptions, new { @class = "form-control" })
                    </div>
                    <div class="col-md-3 form-group">
                        <label>Công đoạn phát sinh <span class="label-jp">発生工程</span> <span class="manual-input-badge">Nhập tay</span></label>
                        @Html.DropDownListFor(m => m.OccurrenceProcess, (List<SelectListItem>)ViewBag.ProcessOptions, new { @class = "form-control" })
                    </div>
                    <div class="col-md-3 form-group">
                        <label>B-action</label>
                        @Html.DropDownListFor(m => m.BAction, (List<SelectListItem>)ViewBag.BActionOptions, new { @class = "form-control" })
                    </div>
                    <div class="col-md-3 form-group">
                        <label>Nhà máy <span class="label-jp">工場</span></label>
                        @Html.DropDownListFor(m => m.Factory, (List<SelectListItem>)ViewBag.FactoryOptions, new { @class = "form-control" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3 form-group">
                        <label>Chuyền <span class="label-jp">ライン</span></label>
                        @Html.TextBoxFor(m => m.Line, new { @class = "form-control", placeholder = "Số chuyền..." })
                    </div>
                    <div class="col-md-3 form-group">
                        <label>Số máy phát sinh <span class="label-jp">発生台数</span></label>
                        @Html.TextBoxFor(m => m.OccurrenceCount, new { @class = "form-control", type = "number", placeholder = "0" })
                    </div>
                    <div class="col-md-3 form-group">
                        <label>Ngày giờ phát sinh <span class="label-jp">発生日</span></label>
                        @Html.TextBoxFor(m => m.OccurrenceDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    </div>
                    <div class="col-md-3 form-group">
                        <label>Lỗi mãn tính <span class="label-jp">慢性不良</span></label>
                        @Html.TextBoxFor(m => m.ChronicDefect, new { @class = "form-control" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group">
                        <label>Thời gian dừng chuyền <span class="label-jp">ライン停止時間</span> <span class="manual-input-badge">Nhập tay</span></label>
                        @Html.TextBoxFor(m => m.LineStopTime, new { @class = "form-control", placeholder = "Nhập thời gian dừng chuyền..." })
                    </div>
                </div>
            </div>
        </div>

        <div class="iss-card">
            <div class="iss-card-header">
                Nội dung điều tra <span style="font-weight:400;">調査内容</span>
            </div>
            <div class="iss-card-body">
                <div class="row">
                    <div class="col-md-12 form-group">
                        <label>Nội dung điều tra <span class="label-jp">調査内容</span></label>
                        @Html.TextAreaFor(m => m.InvestigationContent, new { @class = "form-control", rows = 3, placeholder = "Nhập nội dung điều tra..." })
                    </div>
                </div>

                <div class="ea-section-panel">
                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label>Mã linh kiện 1 <span class="label-jp">部品コード1</span> <span class="manual-input-badge">Nhập tay</span></label>
                            @Html.TextBoxFor(m => m.PartCode1, new { @class = "form-control", placeholder = "Nhập mã linh kiện..." })
                        </div>
                        <div class="col-md-4 form-group">
                            <label>Tên linh kiện <span class="label-jp">部品名前</span></label>
                            @Html.TextBoxFor(m => m.PartName1, new { @class = "form-control form-control-readonly", placeholder = "Tự động hiển thị tên", @readonly = "readonly" })
                            <div class="auto-fill-hint">Tự động hiển thị tên theo mã đã nhập.</div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label>Mã linh kiện 2 <span class="label-jp">部品コード2</span> <span class="manual-input-badge">Nhập tay</span></label>
                            @Html.TextBoxFor(m => m.PartCode2, new { @class = "form-control", placeholder = "Nhập mã linh kiện..." })
                        </div>
                        <div class="col-md-4 form-group">
                            <label>Tên linh kiện <span class="label-jp">部品名前</span></label>
                            @Html.TextBoxFor(m => m.PartName2, new { @class = "form-control form-control-readonly", placeholder = "Tự động hiển thị tên", @readonly = "readonly" })
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label>Mã linh kiện 3 <span class="label-jp">部品コード3</span></label>
                            @Html.TextBoxFor(m => m.PartCode3, new { @class = "form-control", placeholder = "Nhập mã linh kiện..." })
                        </div>
                        <div class="col-md-4 form-group">
                            <label>Tên linh kiện <span class="label-jp">部品名前</span></label>
                            @Html.TextBoxFor(m => m.PartName3, new { @class = "form-control form-control-readonly", placeholder = "Tự động hiển thị tên", @readonly = "readonly" })
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label>Tiến độ điều tra <span class="label-jp">調査進捗</span> <span class="manual-input-badge">Nhập tay</span></label>
                        @Html.DropDownListFor(m => m.InvestigationProgress, (List<SelectListItem>)ViewBag.ProgressOptions, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Phân loại nguyên nhân <span class="label-jp">原因分離</span> <span class="manual-input-badge">Nhập tay</span></label>
                        @Html.DropDownListFor(m => m.CauseClassification, (List<SelectListItem>)ViewBag.CauseOptions, new { @class = "form-control" })
                    </div>
                </div>
            </div>
        </div>

        <div class="iss-card">
            <div class="iss-card-header">
                Chi tiết nguyên nhân <span style="font-weight:400;">詳細原因</span>
            </div>
            <div class="iss-card-body">
                <div class="row">
                    <div class="col-md-12 form-group">
                        <label>Chi tiết nguyên nhân <span class="label-jp">詳細原因</span></label>
                        @Html.TextAreaFor(m => m.DetailedCause, new { @class = "form-control", rows = 3, placeholder = "Mô tả chi tiết nguyên nhân..." })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 form-group">
                        <label>Thời gian bắt đầu điều tra <span class="label-jp">調査開始時間</span></label>
                        @Html.TextBoxFor(m => m.InvestigationStartTime, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local" })
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Thời gian kết thúc điều tra <span class="label-jp">原因決定時間</span></label>
                        @Html.TextBoxFor(m => m.InvestigationEndTime, "{0:yyyy-MM-ddTHH:mm}", new { @class = "form-control", type = "datetime-local" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3 form-group">
                        <label>Số ngày nghỉ</label>
                        @Html.TextBoxFor(m => m.DaysOff, new { @class = "form-control", type = "number", placeholder = "0", id = "daysOff" })
                    </div>
                    <div class="col-md-3 form-group">
                        <label>Số ngày ca đêm</label>
                        @Html.TextBoxFor(m => m.NightShiftDays, new { @class = "form-control", type = "number", placeholder = "0", id = "nightShift" })
                    </div>
                    <div class="col-md-6 form-group">
                        <label>Thời gian điều tra <span class="label-jp">調査時間 (h)</span></label>
                        @Html.TextBoxFor(m => m.InvestigationHours, new { @class = "form-control form-control-readonly", @readonly = "readonly", id = "investigationHours" })
                        <div class="formula-display" style="margin-top:6px;">
                            = (Số ngày điều tra - Số ngày nghỉ) x 24 - (Số ngày ca đêm - Số ngày nghỉ) x 15.4
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="iss-card">
            <div class="iss-card-header">
                Nội dung phân tích &amp; Hành động tiếp theo
            </div>
            <div class="iss-card-body">
                <div class="row">
                    <div class="col-md-12 form-group">
                        <label>Nội dung phân tích <span class="label-jp">解析内容</span></label>
                        @Html.TextAreaFor(m => m.AnalysisContent, new { @class = "form-control", rows = 3, placeholder = "Nhập nội dung phân tích..." })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 form-group">
                        <label>Hành động tiếp theo <span class="label-jp">次のACTION</span></label>
                        @Html.TextAreaFor(m => m.NextAction, new { @class = "form-control", rows = 2, placeholder = "Mô tả hành động tiếp theo..." })
                    </div>
                </div>
            </div>
        </div>

        <div class="iss-card">
            <div class="iss-card-header">
                Đối sách tạm thời <span style="font-weight:400;">暫定対策</span>
            </div>
            <div class="iss-card-body">
                <div class="row">
                    <div class="col-md-4 form-group">
                        <label>Phân loại đối sách tạm thời <span class="label-jp">暫定対策分類</span></label>
                        @Html.DropDownListFor(m => m.TemporaryMeasureClassification, (List<SelectListItem>)ViewBag.TempMeasureOptions, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Thời gian thực hiện ĐSTT <span class="label-jp">暫定対策実施時</span></label>
                        @Html.TextBoxFor(m => m.TemporaryMeasureDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 form-group">
                        <label>Chi tiết đối sách tạm thời <span class="label-jp">暫定対策内容</span></label>
                        @Html.TextAreaFor(m => m.TemporaryMeasureDetail, new { @class = "form-control", rows = 3, placeholder = "Nhập chi tiết đối sách tạm thời..." })
                    </div>
                </div>
            </div>
        </div>

        <div class="iss-card">
            <div class="iss-card-header">
                Đối sách cố hữu <span style="font-weight:400;">恒久対策</span>
            </div>
            <div class="iss-card-body">
                <div class="row">
                    <div class="col-md-4 form-group">
                        <label>Phân loại đối sách cố hữu <span class="label-jp">恒久対策分類</span></label>
                        @Html.DropDownListFor(m => m.PermanentMeasureClassification, (List<SelectListItem>)ViewBag.PermMeasureOptions, new { @class = "form-control" })
                    </div>
                    <div class="col-md-4 form-group">
                        <label>Thời gian thực hiện ĐSCH <span class="label-jp">恒久対策実施時</span></label>
                        @Html.TextBoxFor(m => m.PermanentMeasureDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12 form-group">
                        <label>Chi tiết đối sách cố hữu <span class="label-jp">恒久対策内容</span></label>
                        @Html.TextAreaFor(m => m.PermanentMeasureDetail, new { @class = "form-control", rows = 3, placeholder = "Nhập chi tiết đối sách cố hữu..." })
                    </div>
                </div>
            </div>
        </div>

        <div class="iss-card">
            <div class="iss-card-header">
                Báo cáo đính kèm <span style="font-weight:400;">添付レポート</span>
            </div>
            <div class="iss-card-body">
                <div class="row">
                    <div class="col-md-6 form-group">
                        <label>Chọn file đính kèm</label>
                        <input type="file" name="attachment" class="form-control ea-file-input" />
                        <div class="ea-inline-note">Hỗ trợ: PDF, Excel, Word, hình ảnh.</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="btn-group-iss">
            <button type="submit" class="btn-iss btn-iss-primary">
                Lưu <span style="font-size:12px;">保存</span>
            </button>
            <button type="submit" name="action" value="edit" class="btn-iss btn-iss-warning">
                Biên soạn <span style="font-size:12px;">編集</span>
            </button>
            <a href="@Url.Action("Index")" class="btn-iss btn-iss-secondary">
                Hủy biên soạn
            </a>
        </div>

        <div style="text-align:center; margin-top:16px; margin-bottom:20px;">
            <div class="note-bubble">
                Các thông tin sẽ tự động cập nhật lên danh sách lỗi.
            </div>
        </div>
    }
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            function calcHours() {
                var startEl = $('input[name="InvestigationStartTime"]');
                var endEl = $('input[name="InvestigationEndTime"]');
                var daysOff = parseInt($('#daysOff').val()) || 0;
                var nightShift = parseInt($('#nightShift').val()) || 0;

                if (startEl.val() && endEl.val()) {
                    var start = new Date(startEl.val());
                    var end = new Date(endEl.val());
                    var diffDays = (end - start) / (1000 * 60 * 60 * 24);
                    var hours = (diffDays - daysOff) * 24 - (nightShift - daysOff) * 15.4;
                    $('#investigationHours').val(hours.toFixed(1));
                } else {
                    $('#investigationHours').val('');
                }
            }

            $('input[name="InvestigationStartTime"], input[name="InvestigationEndTime"], #daysOff, #nightShift').on('change keyup', calcHours);
            calcHours();
        });
    </script>
}