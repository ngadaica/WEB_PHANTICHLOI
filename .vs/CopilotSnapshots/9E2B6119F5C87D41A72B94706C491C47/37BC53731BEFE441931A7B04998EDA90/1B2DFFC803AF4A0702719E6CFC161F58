        public static List<SelectListItem> GetSelectList(string groupCode, string emptyText)
        {
            var items = new List<SelectListItem>();

            if (!string.IsNullOrWhiteSpace(emptyText))
            {
                items.Add(new SelectListItem
                {
                    Value = string.Empty,
                    Text = emptyText
                });
            }

            try
            {
                using (var context = new ErrorAnalysisDbContext())
                {
                    const string sql = @"
SELECT [Value], DisplayText
FROM dbo.ErrorAnalysisLookups
WHERE GroupCode = @p0 AND IsActive = 1
ORDER BY SortOrder";

                    var lookupItems = context.Database.SqlQuery<LookupSelectRow>(sql, groupCode).ToList();

                    if (lookupItems.Any())
                    {
                        items.AddRange(lookupItems.Select(x => new SelectListItem
                        {
                            Value = x.Value,
                            Text = x.DisplayText
                        }));

                        return items;
                    }
                }
            }
            catch
            {
            }

            List<ErrorAnalysisLookup> fallbackItems;
            if (LookupData.TryGetValue(groupCode, out fallbackItems))
            {
                items.AddRange(fallbackItems.Select(x => new SelectListItem
                {
                    Value = x.Value,
                    Text = x.DisplayText
                }));
            }

            return items;
        }

        public static List<ErrorAnalysisLookup> GetLookupItems()
        {
            return LookupData.Values
                .SelectMany(x => x)
                .OrderBy(x => x.GroupCode)
                .ThenBy(x => x.SortOrder)
                .ToList();
        }

        private static List<ErrorAnalysisLookup> CreateItems(string groupCode, params string[] values)
        {
            var items = new List<ErrorAnalysisLookup>();

            for (var i = 0; i < values.Length; i++)
            {
                items.Add(new ErrorAnalysisLookup
                {
                    GroupCode = groupCode,
                    Value = values[i],
                    DisplayText = values[i],
                    SortOrder = i + 1,
                    IsActive = true
                });
            }

            return items;
        }
