    </div>

    <div class="iss-card">
        <div class="iss-card-header red">
            <span>&#128681;</span> <span class="lang-vi">Đối sách cố hữu</span><span class="lang-jp">恒久対策</span>
        </div>
        <div class="iss-card-body">
            <div class="row">
                <div class="col-md-4 form-group">
                    <label><span class="lang-vi">Phân loại đối sách cố hữu</span><span class="lang-jp">恒久対策分類</span></label>
                    @Html.DropDownListFor(m => m.PermanentMeasureClassification, (List<SelectListItem>)ViewBag.PermMeasureOptions, new { @class = "form-control" })
                </div>
                <div class="col-md-4 form-group">
                    <label><span class="lang-vi">Thời gian thực hiện ĐSCH</span><span class="lang-jp">恒久対策実施時</span></label>
                    @RenderDateTimePicker("PermanentMeasureDate", Model.PermanentMeasureDate)
                </div>
            </div>

            <div class="row">
                <div class="col-md-12 form-group">
                    <label><span class="lang-vi">Chi tiết đối sách cố hữu</span><span class="lang-jp">恒久対策内容</span></label>
                    @Html.TextAreaFor(m => m.PermanentMeasureDetail, new { @class = "form-control", rows = 3, placeholder = "Nhập chi tiết đối sách cố hữu..." })
                </div>
            </div>
        </div>
    </div>

    <div class="iss-card">
        <div class="iss-card-header brown">
            <span>&#128206;</span> <span class="lang-vi">Tài liệu đính kèm</span><span class="lang-jp">添付資料</span>
        </div>
        <div class="iss-card-body">
            <div class="row">
                <div class="col-md-6 form-group">
                    <label><span class="lang-vi">Chọn tài liệu</span><span class="lang-jp">資料ファイル選択</span></label>
                    <input type="file" name="attachments" id="attachmentsInput" class="form-control ea-file-input" multiple />
                    @if (!string.IsNullOrEmpty(Model.AttachmentPath))
                    {
                        <div class="form-hint" id="currentAttachmentList" style="margin-top:5px;">
                            &#128206; <span class="lang-vi">Tài liệu hiện tại:</span><span class="lang-jp">現在の資料:</span>
                            @foreach (var attachmentPath in ErrorAnalysisDisplayHelper.GetDocumentAttachmentPaths(Model.AttachmentPath))
                            {
                                <div><strong>@ErrorAnalysisDisplayHelper.GetAttachmentDisplayName(attachmentPath, 200)</strong></div>
                            }
                        </div>
                    }
                    <div class="form-hint" id="selectedAttachmentList" style="margin-top:5px; display:none;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="iss-card">
        <div class="iss-card-header brown">
            <span>&#128247;</span> <span class="lang-vi">Ảnh đính kèm</span><span class="lang-jp">添付画像</span>
        </div>
        <div class="iss-card-body">
            <div class="row">
                <div class="col-md-6 form-group">
                    <label><span class="lang-vi">Chọn ảnh</span><span class="lang-jp">画像ファイル選択</span></label>
                    <input type="file" name="images" id="imagesInput" class="form-control ea-file-input" accept="image/*" multiple />
                    @if (!string.IsNullOrEmpty(Model.ImagePath))
                    {
                        <div class="form-hint" id="currentImageList" style="margin-top:5px;">
                            &#128247; <span class="lang-vi">Ảnh hiện tại:</span><span class="lang-jp">現在の画像:</span>
                            @foreach (var imagePath in ErrorAnalysisDisplayHelper.GetImageAttachmentPaths(Model.ImagePath))
                            {
                                <div><strong>@ErrorAnalysisDisplayHelper.GetAttachmentDisplayName(imagePath, 200)</strong></div>
                            }
                        </div>
                    }
                    <div class="form-hint" id="selectedImageList" style="margin-top:5px; display:none;"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="btn-group-iss">
        <button type="submit" class="btn-iss btn-iss-primary">
            <span class="lang-vi">Lưu</span><span class="lang-jp">保存</span>
        </button>
        <button type="submit" name="action" value="edit" class="btn-iss btn-iss-warning">
            <span class="lang-vi">Biên soạn</span><span class="lang-jp">編集</span>
        </button>
        <a href="@Url.Action("Index")" class="btn-iss btn-iss-secondary">
            <span class="lang-vi">Hủy biên soạn</span><span class="lang-jp">キャンセル</span>
        </a>
        <button type="button" class="btn-iss btn-iss-danger" onclick="if(confirm('Bạn có chắc muốn xóa bản ghi này?')) document.getElementById('deleteForm').submit();">
            <span class="lang-vi">Xóa</span><span class="lang-jp">削除</span>
        </button>
    </div>
}

@using (Html.BeginForm("Delete", "ErrorAnalysis", FormMethod.Post, new { id = "deleteForm" }))
{
    @Html.AntiForgeryToken()
    @Html.Hidden("id", Model.Id)
}

@section scripts {
    <script>
        $(document).ready(function () {
            var partLookupTimer;

            function syncDateTimeValue(container) {
                var hiddenInput = container.find('.js-datetime-hidden');
                var dateValue = $.trim(container.find('.js-datetime-date').val() || '');
                var hourValue = parseInt(container.find('.js-datetime-hour').val(), 10);
                var minuteValue = parseInt(container.find('.js-datetime-minute').val(), 10);
                var meridiemValue = container.find('.js-datetime-meridiem').val();

                if (!dateValue) {
                    hiddenInput.val('');
                    return;
                }

                if (isNaN(hourValue)) {
                    hourValue = 0;
                }

                if (isNaN(minuteValue)) {
                    minuteValue = 0;
                }

                var normalizedHour = hourValue;
                if (meridiemValue === 'AM') {
                    normalizedHour = hourValue === 12 ? 0 : hourValue;
                } else {
                    normalizedHour = hourValue === 0 ? 12 : (hourValue < 12 ? hourValue + 12 : 12);
                }

                var hiddenValue = dateValue
                    + 'T'
                    + ('0' + normalizedHour).slice(-2)
                    + ':'
                    + ('0' + minuteValue).slice(-2);

                hiddenInput.val(hiddenValue);
            }

            function syncAllDateTimeValues() {
                $('.iss-datetime-picker').each(function () {
                    syncDateTimeValue($(this));
                });
            }

            function calcHours() {
                syncAllDateTimeValues();
                var startEl = $('input[name="InvestigationStartTime"]');
                var endEl = $('input[name="InvestigationEndTime"]');
                var daysOff = parseInt($('#daysOff').val()) || 0;
                var nightShift = parseInt($('#nightShift').val()) || 0;
                var measurementWaitHours = parseFloat($('#measurementWaitHours').val());
                if (isNaN(measurementWaitHours)) {
                    measurementWaitHours = 0;
                }

                if (startEl.val() && endEl.val()) {
                    var start = new Date(startEl.val());
                    var end = new Date(endEl.val());
                    var diffDays = (end - start) / (1000 * 60 * 60 * 24);
                    var hours = (diffDays - daysOff) * 24 - (nightShift - daysOff) * 15.4 - measurementWaitHours;
                    $('#investigationHours').val(hours.toFixed(1));
                } else {
                    $('#investigationHours').val('');
                }
            }

            function updateSelectedFileList(inputId, listId, currentId, prefixHtml) {
                var input = document.getElementById(inputId);
                var list = $('#' + listId);
                var current = currentId ? $('#' + currentId) : $();
                if (!input || !input.files || input.files.length === 0) {
                    list.hide().html('');
                    current.show();
                    return;
                }

                var html = prefixHtml;
                for (var i = 0; i < input.files.length; i++) {
                    html += '<div><strong>' + $('<div/>').text(input.files[i].name).html() + '</strong></div>';
                }

                list.html(html).show();
                current.hide();
            }

            function updatePartRows() {
                $('.part-row').each(function () {
                    var index = parseInt($(this).data('part-row'));
                    if (index === 1) {
                        $(this).show();
                        return;
                    }

                    var previousCode = $.trim($('input[name="PartCode' + (index - 1) + '"]').val());
                    var currentCode = $.trim($('input[name="PartCode' + index + '"]').val());
                    if (previousCode || currentCode) {
                        $(this).show();
                    } else {
                        $(this).hide();
                        $(this).find('input[type="text"]').val('');
                        $(this).find('select').val('');
                    }
                });
            }

            function updateCauseNote() {
                var value = ($('#causeClassification').val() || '').toLowerCase();
                if (value.indexOf('khác') >= 0 || value.indexOf('その他') >= 0) {
                    $('#causeNoteGroup').show();
                } else {
                    $('#causeNoteGroup').hide();
                    $('input[name="CauseDescription"]').val('');
                }
            }

            function populateSupplierSelect(index, vendors, selectedValue) {
                var select = $('select[name="PartSupplier' + index + '"]');
                var storedValue = $.trim(select.attr('data-selected-value') || '');
                var currentValue = $.trim(select.val() || '');
                var targetValue = $.trim(selectedValue || currentValue || storedValue);
                var options = '<option value="">-- Chọn --</option>';

                for (var i = 0; i < vendors.length; i++) {
                    var vendor = vendors[i] || '';
                    var escapedVendor = $('<div/>').text(vendor).html();
                    var isSelected = targetValue && vendor.toLowerCase() === targetValue.toLowerCase();
                    options += '<option value="' + escapedVendor + '"' + (isSelected ? ' selected="selected"' : '') + '>' + escapedVendor + '</option>';
                }

                select.html(options);
                select.attr('data-selected-value', targetValue);
            }

            function loadPartMasterInfo(index, preserveSelectedSupplier) {
                var code = $.trim($('input[name="PartCode' + index + '"]').val());
                var supplierSelect = $('select[name="PartSupplier' + index + '"]');
                var selectedSupplier = preserveSelectedSupplier ? $.trim(supplierSelect.val() || supplierSelect.attr('data-selected-value') || '') : '';

                if (!code) {
                    $('input[name="PartName' + index + '"]').val('');
                    populateSupplierSelect(index, [], '');
                    return;
                }

                $.getJSON('@Url.Action("GetPartMasterInfo", "ErrorAnalysis")', { material: code })
                    .done(function (response) {
                        $('input[name="PartName' + index + '"]').val(response && response.description ? response.description : '');
                        populateSupplierSelect(index, response && response.vendors ? response.vendors : [], selectedSupplier);
                    })
                    .fail(function () {
                        $('input[name="PartName' + index + '"]').val('');
                        populateSupplierSelect(index, [], '');
                    });
            }

            function updateSelectedAttachments() {
                var input = document.getElementById('attachmentsInput');
                var list = $('#selectedAttachmentList');
                if (!input || !input.files || input.files.length === 0) {
                    list.hide().html('');
                    $('#currentAttachmentList').show();
                    return;
                }

                var html = '&#128206; <span class="lang-vi">File sẽ upload:</span><span class="lang-jp">アップロード予定ファイル:</span>';
                for (var i = 0; i < input.files.length; i++) {
                    html += '<div><strong>' + $('<div/>').text(input.files[i].name).html() + '</strong></div>';
                }

                list.html(html).show();
                $('#currentAttachmentList').hide();
            }

            $('.iss-datetime-picker').on('change', 'input, select', calcHours);
            $('#daysOff, #nightShift, #measurementWaitHours').on('change keyup input', calcHours);
            $(document).on('input change keyup', '.part-code', function () {
                updatePartRows();
                var index = $(this).data('part-index') || $(this).data('part_index');
                clearTimeout(partLookupTimer);
                partLookupTimer = setTimeout(function () {
                    loadPartMasterInfo(index, true);
                }, 300);
            });
            $(document).on('blur', '.part-code', function () {
                var index = $(this).data('part-index') || $(this).data('part_index');
                loadPartMasterInfo(index, true);
            });
            $('#causeClassification').on('change', updateCauseNote);
            $('#attachmentsInput').on('change', function () {
                updateSelectedFileList('attachmentsInput', 'selectedAttachmentList', 'currentAttachmentList', '&#128206; <span class="lang-vi">Tài liệu sẽ upload:</span><span class="lang-jp">アップロード予定資料:</span>');
            });
            $('#imagesInput').on('change', function () {
                updateSelectedFileList('imagesInput', 'selectedImageList', 'currentImageList', '&#128247; <span class="lang-vi">Ảnh sẽ upload:</span><span class="lang-jp">アップロード予定画像:</span>');
            });
            $('form').on('submit', syncAllDateTimeValues);

            calcHours();
            updatePartRows();
            updateCauseNote();

            $('.part-code').each(function () {
                var index = $(this).data('part-index') || $(this).data('part_index');
                loadPartMasterInfo(index, true);
            });
        });
    </script>
}
