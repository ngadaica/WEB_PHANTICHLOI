@model WEB_PHANTICHLOI.Models.ErrorAnalysis
@using WEB_PHANTICHLOI.Models
@using System
@{
    ViewBag.Title = "Chỉnh sửa lỗi #" + (string.IsNullOrWhiteSpace(Model.ManagementNumber) ? Model.Id.ToString() : Model.ManagementNumber);
    Layout = "~/Views/Shared/_ISSLayout.cshtml";
    var canEditPersonInCharge = ViewBag.CanEditPersonInCharge is bool && (bool)ViewBag.CanEditPersonInCharge;
}

@helper RenderDateTimePicker(string fieldName, DateTime? value)
{
    var displayHour = value.HasValue
        ? (value.Value.Hour == 0 ? "00" : (value.Value.Hour > 12 ? (value.Value.Hour - 12).ToString("00") : value.Value.Hour.ToString("00")))
        : "00";
    var minuteValue = value.HasValue ? value.Value.Minute.ToString("00") : "00";
    var meridiem = value.HasValue && value.Value.Hour >= 12 ? "PM" : "AM";

    <div class="iss-datetime-picker" data-target-field="@fieldName">
        <input type="hidden" name="@fieldName" value="@(value.HasValue ? value.Value.ToString("yyyy-MM-ddTHH:mm") : string.Empty)" class="js-datetime-hidden" data-datetime-field="@fieldName" />
        <div class="iss-datetime-picker-row">
            <input type="date" class="form-control js-datetime-date" value="@(value.HasValue ? value.Value.ToString("yyyy-MM-dd") : string.Empty)" />
            <select class="form-control js-datetime-hour">
                @for (var hour = 0; hour <= 12; hour++)
                {
                    var hourText = hour.ToString("00");
                    <option value="@hourText" @(string.Equals(displayHour, hourText, StringComparison.Ordinal) ? "selected" : null)>@hourText</option>
                }
            </select>
            <span class="iss-datetime-separator">:</span>
            <select class="form-control js-datetime-minute">
                @for (var minute = 0; minute < 60; minute++)
                {
                    var minuteText = minute.ToString("00");
                    <option value="@minuteText" @(string.Equals(minuteValue, minuteText, StringComparison.Ordinal) ? "selected" : null)>@minuteText</option>
                }
            </select>
            <select class="form-control js-datetime-meridiem">
                <option value="AM" @(string.Equals(meridiem, "AM", StringComparison.Ordinal) ? "selected" : null)>AM</option>
                <option value="PM" @(string.Equals(meridiem, "PM", StringComparison.Ordinal) ? "selected" : null)>PM</option>
            </select>
        </div>
    </div>
}

<style>
    .cause-textarea-large {
        min-height: 180px;
    }

    .iss-datetime-picker-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .iss-datetime-picker-row .js-datetime-date {
        flex: 1 1 auto;
    }

    .iss-datetime-picker-row .js-datetime-hour,
    .iss-datetime-picker-row .js-datetime-minute,
    .iss-datetime-picker-row .js-datetime-meridiem {
        width: 88px;
        flex: 0 0 auto;
    }

    .iss-datetime-separator {
        font-weight: 700;
        color: #475569;
    }
</style>

<div style="margin-bottom:15px; display:flex; align-items:center; gap:10px;">
    <a href="@Url.Action("Index")" class="btn-iss btn-iss-secondary" style="font-size:12px; padding:5px 14px; text-decoration:none;">
        &#8592; <span class="lang-vi">Quay lại danh sách</span><span class="lang-jp">一覧に戻る</span>
    </a>
    <span style="font-size:18px; font-weight:700; color:#0f172a; margin-left:10px;"><span class="lang-vi">Chỉnh sửa lỗi</span><span class="lang-jp">不良編集</span> #@(string.IsNullOrWhiteSpace(Model.ManagementNumber) ? Model.Id.ToString() : Model.ManagementNumber)</span>
</div>

