                                @Html.TextBox("PartCode" + i, ViewData.Eval("PartCode" + i), new { @class = "form-control part-code", placeholder = "Nhập mã linh kiện...", data_part_index = i })
                            </div>
                            <div class="col-md-3 form-group">
                                <label><span class="lang-vi">Tên linh kiện</span><span class="lang-jp">部品名前</span></label>
                                @Html.TextBox("PartName" + i, ViewData.Eval("PartName" + i), new { @class = "form-control form-control-readonly part-name", placeholder = "Tự động hiển thị tên", @readonly = "readonly", data_part_index = i })
                            </div>
                            <div class="col-md-3 form-group">
                                <label><span class="lang-vi">Nhà cung cấp</span><span class="lang-jp">仕入先</span></label>
                                @Html.DropDownList(
                                    "PartSupplier" + i,
                                    new SelectList((IEnumerable<SelectListItem>)ViewBag.SupplierOptions, "Value", "Text", ViewData.Eval("PartSupplier" + i)),
                                    new { @class = "form-control part-supplier", data_part_index = i, data_selected_value = ViewData.Eval("PartSupplier" + i) })
                            </div>
                            <div class="col-md-2 form-group">
                                <label>CAV</label>
                                @Html.TextBox("PartCav" + i, ViewData.Eval("PartCav" + i), new { @class = "form-control", placeholder = "Nhập CAV..." })
                            </div>
                            <div class="col-md-2 form-group">
                                <label><span class="lang-vi">Lot linh kiện</span><span class="lang-jp">部品ロット</span></label>
                                @Html.TextBox("PartLot" + i, ViewData.Eval("PartLot" + i), new { @class = "form-control", placeholder = "Nhập lot..." })
                            </div>
