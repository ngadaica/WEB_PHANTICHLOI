@model WEB_PHANTICHLOI.Models.ErrorAnalysisChartViewModel
@{
    ViewBag.Title = "Biểu đồ phân tích lỗi 統計グラフ";
    Layout = "~/Views/Shared/_ISSLayout.cshtml";
}

<style>
    .ea-chart-page {
        max-width: 1440px;
        margin: 0 auto;
    }

    .ea-chart-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 20px;
    }

    .ea-chart-title {
        margin: 0;
        font-size: 24px;
        font-weight: 700;
        color: #1f2937;
    }

    .ea-chart-subtitle {
        margin-top: 4px;
        color: #6b7280;
        font-size: 13px;
    }

    .ea-chart-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
    }

    .ea-chart-card.wide {
        grid-column: span 2;
    }

    .ea-chart-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
        overflow: hidden;
    }

    .ea-chart-card-header {
        padding: 14px 18px;
        border-bottom: 1px solid #e5e7eb;
        font-size: 15px;
        font-weight: 700;
        color: #111827;
        background: #ffffff;
    }

    .ea-chart-card-body {
        padding: 18px;
    }

    .ea-chart-canvas-wrap {
        position: relative;
        height: 340px;
    }

    .ea-chart-card.wide .ea-chart-canvas-wrap {
        height: 380px;
    }

    .ea-chart-summary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border: 1px solid #dbeafe;
        border-radius: 8px;
        background: #eff6ff;
        color: #1d4ed8;
        font-size: 12px;
        font-weight: 600;
        margin-top: 6px;
    }

    @@media (max-width: 992px) {
        .ea-chart-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="ea-chart-page">
    <div class="ea-chart-header">
        <div>
            <h1 class="ea-chart-title"><span class="lang-vi">Biểu đồ phân tích lỗi</span><span class="lang-jp">故障分析グラフ</span></h1>
            <div class="ea-chart-subtitle"><span class="lang-vi">Thống kê trực quan theo tiến độ, nguyên nhân, người phụ trách, nhà máy, model và thời gian phát sinh.</span><span class="lang-jp">進捗、原因、担当者、工場、機種、発生時期別のビジュアル統計。</span></div>
            <div class="ea-chart-summary"><span class="lang-vi">Tổng số vụ lỗi:</span><span class="lang-jp">不良件数合計:</span> @Model.TotalCount</div>
        </div>
        <a href="@Url.Action("Index")" class="btn-iss btn-iss-secondary" style="text-decoration:none;">
            <span class="lang-vi">Quay lại danh sách</span><span class="lang-jp">一覧に戻る</span>
        </a>
    </div>

    <div class="ea-chart-grid">
        @foreach (var chart in Model.Charts ?? new List<WEB_PHANTICHLOI.Models.ErrorAnalysisChartCardViewModel>())
        {
            var isWide = chart != null && (
                string.Equals(chart.Id, "investigatorDefectChart", StringComparison.OrdinalIgnoreCase)
                || string.Equals(chart.Id, "causeRatioByCategoryChart", StringComparison.OrdinalIgnoreCase));

            <div class="ea-chart-card @(isWide ? "wide" : string.Empty)">
                <div class="ea-chart-card-header">@chart.Title</div>
                <div class="ea-chart-card-body">
                    <div class="ea-chart-canvas-wrap">
                        <canvas id="@chart.Id"></canvas>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section scripts {
    @Scripts.Render("~/Scripts/chart.js")
    <script>
        $(function () {
            if (typeof Chart === 'undefined') {
                console.error('Chart.js chưa được load.');
                return;
            }

            var charts = @Html.Raw(Json.Encode(Model.Charts ?? new List<WEB_PHANTICHLOI.Models.ErrorAnalysisChartCardViewModel>()));

            function formatNumber(value) {
                var number = Number(value || 0);
                if (Math.abs(number - Math.round(number)) < 0.001) {
                    return Math.round(number).toString();
                }

                return number.toFixed(2);
            }

            function createChart(chart) {
                if (!chart || !chart.Id) {
                    return;
                }

                var ctx = document.getElementById(chart.Id);
                if (!ctx) {
                    return;
                }

                var datasets = $.map(chart.Datasets || [], function (dataset) {
                    return {
                        label: dataset.Label,
                        type: dataset.Type || chart.ChartType,
                        data: dataset.Data || [],
                        backgroundColor: dataset.BackgroundColor,
                        borderColor: dataset.BorderColor,
                        borderWidth: dataset.BorderWidth || 1,
                        fill: dataset.Fill,
                        tension: dataset.Tension || 0,
                        yAxisID: dataset.YAxisId || 'y',
                        stack: dataset.Stack || undefined,
                        order: dataset.Order || 0,
                        borderRadius: chart.ChartType === 'bar' ? 4 : 0,
                        maxBarThickness: 34,
                        pointRadius: (dataset.Type || chart.ChartType) === 'line' ? 4 : 0,
                        pointBackgroundColor: dataset.BorderColor || dataset.BackgroundColor
                    };
                });

                new Chart(ctx, {
                    type: chart.ChartType || 'bar',
                    data: {
                        labels: chart.Labels || [],
                        datasets: datasets
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        indexAxis: chart.Horizontal ? 'y' : 'x',
                        interaction: {
                            mode: 'index',
                            intersect: false
                        },
                        plugins: {
                            legend: {
                                display: chart.ShowLegend,
                                position: chart.ChartType === 'pie' ? 'right' : 'top'
                            },
                            tooltip: {
                                callbacks: {
                                    label: function (context) {
                                        var label = context.dataset && context.dataset.label ? context.dataset.label + ': ' : '';
                                        return label + formatNumber(context.raw);
                                    }
                                }
                            }
                        },
                        scales: chart.ChartType === 'pie'
                            ? {}
                            : {
                                x: {
                                    stacked: chart.Stacked,
                                    beginAtZero: true,
                                    ticks: {
                                        autoSkip: false,
                                        maxRotation: 0,
                                        minRotation: 0
                                    }
                                },
                                y: {
                                    stacked: chart.Stacked,
                                    beginAtZero: true,
                                    title: {
                                        display: !!chart.YAxisTitle,
                                        text: chart.YAxisTitle || ''
                                    },
                                    ticks: {
                                        callback: function (value) {
                                            return formatNumber(value);
                                        }
                                    }
                                },
                                y1: chart.SecondaryYAxisTitle ? {
                                    position: 'right',
                                    beginAtZero: true,
                                    grid: {
                                        drawOnChartArea: false
                                    },
                                    title: {
                                        display: true,
                                        text: chart.SecondaryYAxisTitle
                                    },
                                    ticks: {
                                        callback: function (value) {
                                            return formatNumber(value);
                                        }
                                    }
                                } : undefined
                            }
                    }
                });
            }

            $.each(charts, function (_, chart) {
                createChart(chart);
            });
        });
    </script>
}