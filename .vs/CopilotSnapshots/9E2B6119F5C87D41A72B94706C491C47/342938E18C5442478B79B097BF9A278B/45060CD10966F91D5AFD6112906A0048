@model WEB_PHANTICHLOI.Models.ErrorAnalysisChartViewModel
@{
    ViewBag.Title = "Biểu đồ phân tích lỗi 統計グラフ";
    Layout = "~/Views/Shared/_ISSLayout.cshtml";
}

<style>
    .ea-chart-page {
        max-width: 1440px;
        margin: 0 auto;
    }

    .ea-chart-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 20px;
    }

    .ea-chart-title {
        margin: 0;
        font-size: 24px;
        font-weight: 700;
        color: #1f2937;
    }

    .ea-chart-subtitle {
        margin-top: 4px;
        color: #6b7280;
        font-size: 13px;
    }

    .ea-chart-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
    }

    .ea-chart-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        box-shadow: 0 4px 16px rgba(15, 23, 42, 0.05);
        overflow: hidden;
    }

    .ea-chart-card-header {
        padding: 14px 18px;
        border-bottom: 1px solid #e5e7eb;
        font-size: 15px;
        font-weight: 700;
        color: #111827;
        background: #ffffff;
    }

    .ea-chart-card-body {
        padding: 18px;
    }

    .ea-chart-canvas-wrap {
        position: relative;
        height: 340px;
    }

    .ea-chart-summary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border: 1px solid #dbeafe;
        border-radius: 8px;
        background: #eff6ff;
        color: #1d4ed8;
        font-size: 12px;
        font-weight: 600;
        margin-top: 6px;
    }

    @@media (max-width: 992px) {
        .ea-chart-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="ea-chart-page">
    <div class="ea-chart-header">
        <div>
            <h1 class="ea-chart-title"><span class="lang-vi">Biểu đồ phân tích lỗi</span><span class="lang-jp">故障分析グラフ</span></h1>
            <div class="ea-chart-subtitle"><span class="lang-vi">Thống kê trực quan theo tiến độ, nguyên nhân, người phụ trách, nhà máy, model và thời gian phát sinh.</span><span class="lang-jp">進捗、原因、担当者、工場、機種、発生時期別のビジュアル統計。</span></div>
            <div class="ea-chart-summary"><span class="lang-vi">Tổng số vụ lỗi:</span><span class="lang-jp">不良件数合計:</span> @Model.TotalCount</div>
        </div>
        <a href="@Url.Action("Index")" class="btn-iss btn-iss-secondary" style="text-decoration:none;">
            <span class="lang-vi">Quay lại danh sách</span><span class="lang-jp">一覧に戻る</span>
        </a>
    </div>

    <div class="ea-chart-grid">
        <div class="ea-chart-card">
            <div class="ea-chart-card-header"><span class="lang-vi">Tiến độ điều tra</span><span class="lang-jp">調査進捗</span></div>
            <div class="ea-chart-card-body">
                <div class="ea-chart-canvas-wrap">
                    <canvas id="progressChart"></canvas>
                </div>
            </div>
        </div>

        <div class="ea-chart-card">
            <div class="ea-chart-card-header"><span class="lang-vi">Phân loại nguyên nhân</span><span class="lang-jp">原因分類</span></div>
            <div class="ea-chart-card-body">
                <div class="ea-chart-canvas-wrap">
                    <canvas id="causeChart"></canvas>
                </div>
            </div>
        </div>

        <div class="ea-chart-card">
            <div class="ea-chart-card-header"><span class="lang-vi">Đảm nhiệm</span><span class="lang-jp">担当者</span></div>
            <div class="ea-chart-card-body">
                <div class="ea-chart-canvas-wrap">
                    <canvas id="investigatorChart"></canvas>
                </div>
            </div>
        </div>

        <div class="ea-chart-card">
            <div class="ea-chart-card-header"><span class="lang-vi">Số vụ phát sinh theo nhà máy</span><span class="lang-jp">工場別発生件数</span></div>
            <div class="ea-chart-card-body">
                <div class="ea-chart-canvas-wrap">
                    <canvas id="factoryChart"></canvas>
                </div>
            </div>
        </div>

        <div class="ea-chart-card">
            <div class="ea-chart-card-header"><span class="lang-vi">Top model phát sinh lỗi</span><span class="lang-jp">不良発生トップ機種</span></div>
            <div class="ea-chart-card-body">
                <div class="ea-chart-canvas-wrap">
                    <canvas id="modelChart"></canvas>
                </div>
            </div>
        </div>

        <div class="ea-chart-card">
            <div class="ea-chart-card-header"><span class="lang-vi">Xu hướng lỗi theo tháng</span><span class="lang-jp">月別不良推移</span></div>
            <div class="ea-chart-card-body">
                <div class="ea-chart-canvas-wrap">
                    <canvas id="monthlyChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    @Scripts.Render("~/Scripts/chart.js")
    <script>
        $(function () {
            if (typeof Chart === 'undefined') {
                console.error('Chart.js chưa được load.');
                return;
            }

            var progressLabels = @Html.Raw(Json.Encode(Model.ProgressLabels));
            var progressData = @Html.Raw(Json.Encode(Model.ProgressData));

            var causeLabels = @Html.Raw(Json.Encode(Model.CauseLabels));
            var causeData = @Html.Raw(Json.Encode(Model.CauseData));

            var investigatorLabels = @Html.Raw(Json.Encode(Model.InvestigatorLabels));
            var investigatorData = @Html.Raw(Json.Encode(Model.InvestigatorData));

            var factoryLabels = @Html.Raw(Json.Encode(Model.FactoryLabels));
            var factoryData = @Html.Raw(Json.Encode(Model.FactoryData));

            var modelLabels = @Html.Raw(Json.Encode(Model.ModelLabels));
            var modelData = @Html.Raw(Json.Encode(Model.ModelData));

            var monthlyLabels = @Html.Raw(Json.Encode(Model.MonthlyLabels));
            var monthlyData = @Html.Raw(Json.Encode(Model.MonthlyData));

            var palette = [
                '#4f46e5', '#0ea5e9', '#10b981', '#f59e0b', '#ef4444',
                '#8b5cf6', '#14b8a6', '#f97316', '#64748b', '#ec4899'
            ];

            function createPieChart(id, labels, data) {
                new Chart(document.getElementById(id), {
                    type: 'doughnut',
                    data: {
                        labels: labels,
                        datasets: [{
                            data: data,
                            backgroundColor: palette,
                            borderColor: '#ffffff',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'right'
                            }
                        }
                    }
                });
            }

            function createBarChart(id, labels, data, horizontal) {
                new Chart(document.getElementById(id), {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: (localStorage.getItem('isJp')==='true') ? '件数' : 'Số vụ',
                            data: data,
                            backgroundColor: '#4a72b8',
                            borderRadius: 4,
                            maxBarThickness: 34
                        }]
                    },
                    options: {
                        indexAxis: horizontal ? 'y' : 'x',
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true
                            },
                            x: {
                                beginAtZero: true
                            }
                        }
                    }
                });
            }

            function createLineChart(id, labels, data) {
                new Chart(document.getElementById(id), {
                    type: 'line',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: (localStorage.getItem('isJp')==='true') ? '不良件数' : 'Số vụ lỗi',
                            data: data,
                            borderColor: '#2563eb',
                            backgroundColor: 'rgba(37, 99, 235, 0.12)',
                            fill: true,
                            tension: 0.3,
                            pointRadius: 4,
                            pointBackgroundColor: '#2563eb'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    precision: 0
                                }
                            }
                        }
                    }
                });
            }

            createPieChart('progressChart', progressLabels, progressData);
            createPieChart('causeChart', causeLabels, causeData);
            createBarChart('investigatorChart', investigatorLabels, investigatorData, false);
            createBarChart('factoryChart', factoryLabels, factoryData, false);
            createBarChart('modelChart', modelLabels, modelData, true);
            createLineChart('monthlyChart', monthlyLabels, monthlyData);
        });
    </script>
}