                            <th style="min-width:90px;"><span class="lang-vi">Chủng loại</span><span class="lang-jp">不良分類</span></th>
                            <th style="min-width:90px;"><span class="lang-vi">Đảm nhiệm</span><span class="lang-jp">担当者</span></th>
