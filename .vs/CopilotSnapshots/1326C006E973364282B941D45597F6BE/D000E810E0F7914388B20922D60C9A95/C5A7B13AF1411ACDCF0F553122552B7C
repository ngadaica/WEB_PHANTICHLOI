            }
        </div>

        @using (Html.BeginForm("Delete", "ErrorAnalysis", FormMethod.Post, new { id = "deleteErrorForm", style = "display:none;" }))
        {
            @Html.AntiForgeryToken()
            @Html.Hidden("id", string.Empty, new { id = "deleteErrorId" })
        }

        <div id="imagePreviewModal" class="image-preview-modal">
            <div class="image-preview-dialog">
                <button type="button" class="image-preview-close" id="closeImagePreview">&times;</button>
                <div style="font-size:18px; font-weight:700; color:#0f172a;">Preview ảnh</div>
                <div class="image-preview-gallery" id="imagePreviewGallery"></div>
