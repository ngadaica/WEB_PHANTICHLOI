<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - ISS | BIVN Brother</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <style>
        /* === ISS Global Styles === */
        * { box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f0f2f5;
            margin: 0;
            padding: 0;
            font-size: 13px;
        }

        /* === Header === */
        .iss-header {
            background: linear-gradient(135deg, #1a237e 0%, #283593 40%, #3949ab 100%);
            color: white;
            padding: 0;
            position: relative;
            overflow: hidden;
            box-shadow: 0 3px 10px rgba(0,0,0,0.3);
        }
        .iss-header::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120"><path fill="rgba(255,255,255,0.03)" d="M0,60 Q300,0 600,60 T1200,60 V120 H0Z"/></svg>') repeat-x bottom;
            pointer-events: none;
        }
        .iss-header-content {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 20px;
            position: relative;
            z-index: 1;
        }
        .iss-header-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .iss-logo-badge {
            background: linear-gradient(145deg, #ffd600, #ffab00);
            color: #1a237e;
            border-radius: 12px;
            padding: 8px 14px;
            font-weight: 900;
            font-size: 11px;
            line-height: 1.3;
            text-align: center;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }
        .iss-logo-badge .years {
            font-size: 22px;
            display: block;
        }
        .iss-title-block h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 700;
            letter-spacing: 1px;
            text-shadow: 1px 1px 3px rgba(0,0,0,0.3);
        }
        .iss-title-block h2 {
            margin: 2px 0 0;
            font-size: 14px;
            font-weight: 400;
            color: #90caf9;
            font-style: italic;
        }
        .iss-header-right {
            text-align: right;
        }
        .iss-brother-text {
            font-size: 30px;
            font-weight: 800;
            letter-spacing: 3px;
            color: #fff;
            text-shadow: 2px 2px 5px rgba(0,0,0,0.3);
        }
        .iss-brother-sub {
            font-size: 11px;
            color: #bbdefb;
            letter-spacing: 2px;
        }

        /* === Main Navigation Tabs === */
        .iss-main-nav {
            background: #263238;
            padding: 0 15px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }
        .iss-main-nav ul {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            flex-wrap: wrap;
        }
        .iss-main-nav li a {
            display: block;
            padding: 12px 18px;
            color: #b0bec5;
            text-decoration: none;
            font-weight: 600;
            font-size: 13px;
            border-bottom: 3px solid transparent;
            transition: all 0.2s ease;
            white-space: nowrap;
        }
        .iss-main-nav li a:hover {
            color: #fff;
            background: rgba(255,255,255,0.08);
            border-bottom-color: #42a5f5;
        }
        .iss-main-nav li a.active {
            color: #fff;
            background: rgba(255,255,255,0.1);
            border-bottom-color: #ffd600;
        }
        .iss-main-nav li a .nav-jp {
            display: block;
            font-size: 10px;
            font-weight: 400;
            color: #78909c;
            margin-top: 1px;
        }
        .iss-main-nav li a.active .nav-jp,
        .iss-main-nav li a:hover .nav-jp {
            color: #90caf9;
        }

        /* === Sub Navigation === */
        .iss-sub-nav {
            background: #37474f;
            padding: 0 15px;
        }
        .iss-sub-nav ul {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
        }
        .iss-sub-nav li a {
            display: block;
            padding: 9px 16px;
            color: #b0bec5;
            text-decoration: none;
            font-weight: 500;
            font-size: 12px;
            border-bottom: 2px solid transparent;
            transition: all 0.2s ease;
        }
        .iss-sub-nav li a:hover {
            color: #fff;
            background: rgba(255,255,255,0.05);
        }
        .iss-sub-nav li a.active {
            color: #ffd600;
            border-bottom-color: #ffd600;
        }
        .iss-sub-nav li a .sub-jp {
            font-size: 10px;
            color: #78909c;
            margin-left: 4px;
        }

        /* === Content Area === */
        .iss-content {
            padding: 15px 20px;
            min-height: calc(100vh - 200px);
        }

        /* === Card Styles === */
        .iss-card {
            background: #fff;
            border-radius: 10px;
            box-shadow: 0 4px 16px rgba(15, 23, 42, 0.04);
            margin-bottom: 20px;
            border: 1px solid #e2e8f0;
            overflow: hidden;
        }
        .iss-card-header {
            background: #f8fafc;
            color: #0f172a;
            padding: 14px 18px;
            font-weight: 700;
            font-size: 15px;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid #e2e8f0;
            border-left: 5px solid #3b82f6;
        }
        .iss-card-header.green { border-left-color: #10b981; }
        .iss-card-header.orange { border-left-color: #f59e0b; }
        .iss-card-header.purple { border-left-color: #8b5cf6; }
        .iss-card-header.red { border-left-color: #ef4444; }
        .iss-card-header.teal { border-left-color: #14b8a6; }
        .iss-card-header.brown { border-left-color: #8b4513; }
        .iss-card-body {
            padding: 18px;
        }

        /* === Table Styles === */
        .iss-table-wrapper {
            overflow-x: auto;
            border-radius: 6px;
        }
        .iss-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
            min-width: 1800px;
        }
        .iss-table thead th {
            background: linear-gradient(180deg, #1565c0, #0d47a1);
            color: white;
            padding: 8px 6px;
            text-align: center;
            font-weight: 600;
            font-size: 11px;
            border: 1px solid #0d47a1;
            white-space: nowrap;
            position: sticky;
            top: 0;
            z-index: 10;
        }
        .iss-table thead th .th-jp {
            display: block;
            font-size: 9px;
            font-weight: 400;
            opacity: 0.8;
        }
        .iss-table tbody td {
            padding: 6px;
            border: 1px solid #e0e0e0;
            vertical-align: top;
        }
        .iss-table tbody tr:nth-child(even) {
            background: #f5f7fa;
        }
        .iss-table tbody tr:hover {
            background: #e3f2fd;
        }
        .iss-table tbody tr td:first-child {
            text-align: center;
            font-weight: 700;
            color: #1565c0;
        }

        /* === Status Badges === */
        .badge-status {
            display: inline-block;
            padding: 3px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 600;
            white-space: nowrap;
        }
        .badge-close { background: #c8e6c9; color: #2e7d32; }
        .badge-open { background: #fff3e0; color: #e65100; }
        .badge-investigating { background: #e3f2fd; color: #1565c0; }
        .badge-countermeasure { background: #f3e5f5; color: #6a1b9a; }

        /* === Form Styles === */
        .iss-form .form-group {
            margin-bottom: 16px;
        }
        .iss-form label {
            font-weight: 600;
            color: #334155;
            font-size: 13px;
            margin-bottom: 6px;
            display: block;
        }
        .iss-form label .label-jp {
            font-weight: 400;
            color: #94a3b8;
            font-size: 12px;
        }
        .iss-form .form-control {
            max-width: 100%;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 14px;
            transition: all 0.2s ease;
            background: #ffffff;
            width: 100%;
        }
        .iss-form .form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
            outline: none;
            background: #ffffff;
        }
        .iss-form textarea.form-control {
            min-height: 80px;
            resize: vertical;
            background: #ffffff;
        }
        .iss-form select.form-control {
            background: #ffffff;
        }
        .iss-form .form-control-readonly {
            background: #f8fafc;
            color: #64748b;
            border-color: #e2e8f0;
        }
        .iss-form .required-marker {
            color: #ef4444;
            font-weight: 700;
        }
        .iss-form .form-hint {
            font-size: 12px;
            color: #94a3b8;
            margin-top: 4px;
        }

        /* === Buttons === */
        .btn-iss {
            padding: 10px 20px;
            border: 1px solid transparent;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            text-decoration: none;
        }
        .btn-iss-primary { background: #3b82f6; color: white; }
        .btn-iss-primary:hover { background: #2563eb; color: white; transform: translateY(-1px); box-shadow: 0 4px 6px rgba(37, 99, 235, 0.2); }
        .btn-iss-success { background: #10b981; color: white; }
        .btn-iss-success:hover { background: #059669; color: white; transform: translateY(-1px); box-shadow: 0 4px 6px rgba(16, 185, 129, 0.2); }
        .btn-iss-warning { background: #f59e0b; color: white; }
        .btn-iss-warning:hover { background: #d97706; color: white; transform: translateY(-1px); box-shadow: 0 4px 6px rgba(245, 158, 11, 0.2); }
        .btn-iss-danger { background: #ef4444; color: white; }
        .btn-iss-danger:hover { background: #dc2626; color: white; transform: translateY(-1px); box-shadow: 0 4px 6px rgba(239, 68, 68, 0.2); }
        .btn-iss-secondary { background: #ffffff; color: #475569; border-color: #cbd5e1; }
        .btn-iss-secondary:hover { background: #f8fafc; color: #0f172a; text-decoration: none; }

        .btn-group-iss {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 24px;
            padding-top: 20px;
            border-top: 1px solid #e2e8f0;
            justify-content: center;
        }

        /* === Section Checkbox Header === */
        .section-check-header {
            display: flex;
            align-items: center;
            gap: 6px;
            font-weight: 700;
            color: #1565c0;
            font-size: 13px;
            margin-bottom: 10px;
            padding-bottom: 5px;
            border-bottom: 2px solid #bbdefb;
        }
        .section-check-header input[type="checkbox"] {
            accent-color: #1565c0;
            width: 16px;
            height: 16px;
        }

        /* === Formula Display === */
        .formula-display {
            background: #fff9c4;
            border: 1px solid #f9a825;
            border-radius: 4px;
            padding: 6px 10px;
            font-size: 12px;
            color: #f57f17;
            font-style: italic;
        }

        /* === Auto-fill hint === */
        .auto-fill-hint {
            background: #fff3e0;
            border: 1px solid #ffb74d;
            border-radius: 6px;
            padding: 8px 12px;
            font-size: 12px;
            color: #e65100;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            margin: 3px 0;
        }

        /* === Pagination === */
        .iss-pagination {
            display: flex;
            justify-content: center;
            gap: 4px;
            margin-top: 15px;
        }
        .iss-pagination a, .iss-pagination span {
            padding: 5px 12px;
            border: 1px solid #cfd8dc;
            border-radius: 4px;
            text-decoration: none;
            color: #37474f;
            font-size: 12px;
        }
        .iss-pagination a:hover { background: #e3f2fd; }
        .iss-pagination .active { background: #1565c0; color: white; border-color: #1565c0; }

        /* === Footer === */
        .iss-footer {
            background: #263238;
            color: #78909c;
            text-align: center;
            padding: 10px;
            font-size: 11px;
        }
        .iss-footer a {
            color: #90caf9;
            text-decoration: none;
        }

        /* === Responsive === */
        @@media (max-width: 768px) {
            .iss-header-content { flex-direction: column; text-align: center; gap: 10px; }
            .iss-main-nav ul { flex-wrap: wrap; justify-content: center; }
            .iss-main-nav li a { padding: 8px 12px; font-size: 12px; }
        }

        /* === Tooltip-like notes === */
        .note-bubble {
            background: #fff9c4;
            border: 1px solid #f9a825;
            border-radius: 8px;
            padding: 8px 12px;
            font-size: 12px;
            color: #795548;
            position: relative;
            display: inline-block;
            margin-top: 5px;
        }
        .note-bubble::before {
            content: '';
            position: absolute;
            top: -8px;
            left: 20px;
            border-left: 8px solid transparent;
            border-right: 8px solid transparent;
            border-bottom: 8px solid #f9a825;
        }

        /* === Enter manually badge === */
        .manual-input-badge {
            background: #ffcc80;
            color: #e65100;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 10px;
            font-weight: 600;
            margin-left: 5px;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <div class="iss-header">
        <div class="iss-header-content">
            <div class="iss-header-left">
                <div class="iss-logo-badge">
                    <span class="years">20</span>
                    YEARS<br />ANNIVERSARY
                </div>
                <div class="iss-title-block">
                    <h1>Intelligent Support System</h1>
                    <h2>R&amp;D Dept. DE section</h2>
                </div>
            </div>
            <div class="iss-header-right">
                <div class="iss-brother-text">brother</div>
                <div class="iss-brother-sub">BIVN &bull; at your side.</div>
            </div>
        </div>
    </div>

    <!-- Main Navigation -->
    <nav class="iss-main-nav">
        <ul>
            <li>
                <a href="@Url.Action("Index", "ErrorAnalysis")" class="@(ViewContext.RouteData.Values["controller"].ToString() == "ErrorAnalysis" ? "active" : "")">
                    Phân tích lỗi <span class="nav-jp">故障分析</span>
                </a>
            </li>
            <li><a href="#">Phân tích tiếng kêu <span class="nav-jp">異音分析  </span></a></li>
            <li><a href="#">Phân tích hình ảnh <span class="nav-jp">画像解析   </span></a></li>
            <li><a href="#">Mã lỗi <span class="nav-jp">エラーコード </span></a></li>
            <li><a href="#">RIP MAP<span class="nav-jp">RIP MAP</span></a></li>
            <li><a href="#">ROLLER MAP<span class="nav-jp">ROLLER MAP</span></a></li>
            <li><a href="#">Thông tin linh kiện <span class="nav-jp">部品情報   </span></a></li>
            <li><a href="#">Thông tin sản phẩm <span class="nav-jp">製品情報   </span></a></li>
            <li><a href="#">Thông tin điều tra <span class="nav-jp">調査情報</span></a></li>
            <li><a href="#">Chức năng <span class="nav-jp">機能 </span></a></li>
        </ul>
    </nav>

    <!-- Sub Navigation - context specific -->
    @if (ViewContext.RouteData.Values["controller"].ToString() == "ErrorAnalysis")
    {
        <nav class="iss-sub-nav">
            <ul>
                <li>
                    <a href="@Url.Action("Index", "ErrorAnalysis")"
                       class="@(ViewContext.RouteData.Values["action"].ToString() == "Index" ? "active" : "")">
                        Danh sách lỗi <span class="sub-jp">エラー一覧</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Create", "ErrorAnalysis")"
                       class="@(ViewContext.RouteData.Values["action"].ToString() == "Create" ? "active" : "")">
                        Thêm mới <span class="sub-jp">新規登録</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Search", "ErrorAnalysis")"
                       class="@(ViewContext.RouteData.Values["action"].ToString() == "Search" ? "active" : "")">
                        Tìm kiếm <span class="sub-jp">検索</span>
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Chart", "ErrorAnalysis")"
                       class="@(ViewContext.RouteData.Values["action"].ToString() == "Chart" ? "active" : "")">
                        Biểu đồ <span class="sub-jp">統計グラフ</span>
                    </a>
                </li>
            </ul>
        </nav>
    }

    <!-- Content -->
    <div class="iss-content">
        @RenderBody()
    </div>

    <!-- Footer -->
    <div class="iss-footer">
        &copy; @DateTime.Now.Year <strong>BIVN Brother</strong> | R&amp;D Dept. DE section | Intelligent Support System v1.0
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
