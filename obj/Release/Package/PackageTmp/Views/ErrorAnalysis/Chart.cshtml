    }

    .ea-period-filter-wrap {
        display: flex;
        flex-direction: column;
        gap: 14px;
        max-height: 320px;
        overflow-y: auto;
        padding-right: 4px;
    }

    .ea-period-year-block {
        border: 1px solid #dbe8cb;
        border-radius: 14px;
        background: linear-gradient(180deg, #fdfefb 0%, #f6faef 100%);
        padding: 10px;
    }

    .ea-period-year-label {
        color: #4d6631;
        font-size: 12px;
        font-weight: 800;
        margin-bottom: 10px;
