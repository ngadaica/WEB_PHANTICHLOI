@model WEB_PHANTICHLOI.Models.ErrorAnalysisChartViewModel
@using System
@using System.Globalization
@using System.Linq
@using System.Collections.Generic
@{
    ViewBag.Title = "Biểu đồ phân tích lỗi 統計グラフ";
    Layout = "~/Views/Shared/_ISSLayout.cshtml";

    var chartCards = Model.Charts ?? new List<WEB_PHANTICHLOI.Models.ErrorAnalysisChartCardViewModel>();
    var selectedFilterCount =
        (Model.SelectedProgresses ?? Enumerable.Empty<string>()).Count() +
        (Model.SelectedCategories ?? Enumerable.Empty<string>()).Count() +
        (Model.SelectedModels ?? Enumerable.Empty<string>()).Count() +
        (Model.SelectedCauseClassifications ?? Enumerable.Empty<string>()).Count() +
        (Model.SelectedPersonInCharges ?? Enumerable.Empty<string>()).Count() +
        (Model.SelectedChronicDefects ?? Enumerable.Empty<string>()).Count() +
        (Model.SelectedOccurrencePeriods ?? Enumerable.Empty<string>()).Count();
    var hasAnyFilter = selectedFilterCount > 0;
}

@helper RenderFilterGroup(string title, string inputName, IEnumerable<string> options, IEnumerable<string> selectedValues)
{
    var optionList = (options ?? Enumerable.Empty<string>()).ToList();
    var selectedSet = new HashSet<string>(selectedValues ?? Enumerable.Empty<string>(), StringComparer.OrdinalIgnoreCase);

    <div class="ea-filter-group">
        <div class="ea-filter-group-title">
            <span>@title</span>
            <span class="ea-filter-group-count">@optionList.Count</span>
        </div>
        <div class="ea-filter-options">
            @foreach (var option in optionList)
            {
                var optionId = inputName + "_" + option.GetHashCode().ToString().Replace("-", "N");
                <label class="ea-filter-option @(selectedSet.Contains(option) ? "selected" : string.Empty)" for="@optionId">
                    <input type="checkbox"
                           id="@optionId"
                           name="@inputName"
                           value="@option"
                           class="ea-filter-check"
                           @(selectedSet.Contains(option) ? "checked" : null) />
                    <span>@option</span>
                </label>
            }
        </div>
    </div>
}

@helper RenderPeriodFilterGroup(string title, string inputName, IEnumerable<string> options, IEnumerable<string> selectedValues)
{
    var optionList = (options ?? Enumerable.Empty<string>()).ToList();
    var selectedSet = new HashSet<string>(selectedValues ?? Enumerable.Empty<string>(), StringComparer.OrdinalIgnoreCase);
    var groupedOptions = optionList
        .Select(x => new
        {
            Value = x,
            Date = DateTime.TryParseExact(x + "-01", "yyyy-MM-dd", CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsedDate)
                ? (DateTime?)parsedDate
                : null
        })
        .Where(x => x.Date.HasValue)
        .GroupBy(x => x.Date.Value.Year)
        .OrderByDescending(x => x.Key)
        .ToList();

    <div class="ea-filter-group ea-filter-group-period">
        <div class="ea-filter-group-title">
            <span>@title</span>
            <span class="ea-filter-group-count">@optionList.Count</span>
        </div>
        <div class="ea-period-filter-wrap">
            @foreach (var yearGroup in groupedOptions)
            {
                <div class="ea-period-year-block">
                    <div class="ea-period-year-label">@yearGroup.Key</div>
                    <div class="ea-period-options">
                        @foreach (var option in yearGroup.OrderBy(x => x.Date.Value.Month))
                        {
                            var optionId = inputName + "_" + option.Value.Replace("-", string.Empty);
                            var monthLabel = option.Date.Value.ToString("MMM", CultureInfo.InvariantCulture).ToUpperInvariant();
                            <label class="ea-period-option @(selectedSet.Contains(option.Value) ? "selected" : string.Empty)" for="@optionId" title="@option.Date.Value.ToString("MM/yyyy")">
                                <input type="checkbox"
                                       id="@optionId"
                                       name="@inputName"
                                       value="@option.Value"
                                       class="ea-filter-check"
                                       @(selectedSet.Contains(option.Value) ? "checked" : null) />
                                <span>@monthLabel</span>
                            </label>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

<style>
