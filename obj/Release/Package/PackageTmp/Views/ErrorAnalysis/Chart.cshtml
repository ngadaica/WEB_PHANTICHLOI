        .ea-period-option.selected {
            background: linear-gradient(180deg, #d7ebba 0%, #c6e09f 100%);
            border-color: #8eaf60;
            color: #223015;
            box-shadow: 0 8px 16px rgba(120, 150, 80, 0.16);
        }

        .ea-period-option input {
            display: none;
        }

    .ea-chart-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 18px;
    }

    .ea-chart-card {
        background: #ffffff;
        border: 1px solid #e5eadf;
        border-radius: 16px;
        box-shadow: 0 10px 26px rgba(15, 23, 42, 0.05);
