    .ea-period-option {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 38px;
        border: 1px solid #c7ddb0;
        border-radius: 10px;
        background: linear-gradient(180deg, #f8fbf2 0%, #eef6e2 100%);
        color: #476033;
        cursor: pointer;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.04em;
        transition: all 0.18s ease, box-shadow 0.18s ease;
    }

        .ea-period-option:hover {
            border-color: #9fbe77;
            background: linear-gradient(180deg, #eff7e0 0%, #e4f0d0 100%);
            box-shadow: 0 6px 14px rgba(120, 150, 80, 0.12);
