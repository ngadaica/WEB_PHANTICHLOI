@model List<WEB_PHANTICHLOI.Models.ErrorAnalysis>
@{
    ViewBag.Title = "Tìm kiếm lỗi 検索";
    Layout = "~/Views/Shared/_ISSLayout.cshtml";
}

<!-- Search Form -->
<div class="iss-card">
    <div class="iss-card-header">
        <span>&#128269;</span> <span class="lang-vi">Tìm kiếm</span><span class="lang-jp">検索</span>
    </div>
    <div class="iss-card-body">
        @using (Html.BeginForm("Search", "ErrorAnalysis", FormMethod.Get, new { @class = "iss-form" }))
        {
            <div class="row">
                <div class="col-md-4 form-group">
                    <label><span class="lang-vi">Từ khóa tìm kiếm</span><span class="lang-jp">キーワード検索</span></label>
                    <input type="text" name="keyword" class="form-control" style="width:100%;" placeholder="Nhập từ khóa..." value="@ViewBag.Keyword" />
                </div>
                <div class="col-md-2 form-group">
                    <label><span class="lang-vi">Nhà máy</span><span class="lang-jp">工場</span></label>
                    @if (ViewBag.FactoryOptions != null)
                    {
                        @Html.DropDownList("factory", (List<SelectListItem>)ViewBag.FactoryOptions, new { @class = "form-control" })
                    }
                </div>
                <div class="col-md-2 form-group">
                    <label><span class="lang-vi">Trạng thái</span><span class="lang-jp">状態</span></label>
                    @if (ViewBag.ProgressOptions != null)
                    {
                        @Html.DropDownList("status", (List<SelectListItem>)ViewBag.ProgressOptions, new { @class = "form-control" })
                    }
                </div>
                <div class="col-md-2 form-group">
                    <label><span class="lang-vi">Model</span><span class="lang-jp">機種</span></label>
                    <input type="text" name="model" class="form-control" placeholder="Model..." value="@ViewBag.ModelFilter" />
                </div>
                <div class="col-md-2 form-group" style="display:flex; align-items:flex-end;">
                    <button type="submit" class="btn-iss btn-iss-primary" style="width:100%;">
                        &#128269; <span class="lang-vi">Tìm kiếm</span><span class="lang-jp">検索</span>
                    </button>
                </div>
            </div>
        }
    </div>
</div>

<!-- Results -->
@if (Model != null)
{
    <div class="iss-card">
        <div class="iss-card-header green">
            <span>&#128203;</span> <span class="lang-vi">Kết quả tìm kiếm</span><span class="lang-jp">検索結果</span> &nbsp;
            <span style="font-weight:400; font-size:12px;">| @Model.Count <span class="lang-vi">kết quả</span><span class="lang-jp">件</span></span>
        </div>
        <div class="iss-card-body" style="padding:0;">
            @if (Model.Count > 0)
            {
                <div class="iss-table-wrapper" style="max-height:60vh; overflow-y:auto;">
                    <table class="iss-table">
                        <thead>
                            <tr>
                                <th><span class="lang-vi">Số quản lý</span><span class="lang-jp">管理No</span></th>
                                <th><span class="lang-vi">Nhà máy</span><span class="lang-jp">工場</span></th>
                                <th><span class="lang-vi">Trạng thái</span><span class="lang-jp">状態</span></th>
                                <th><span class="lang-vi">Ngày phát sinh</span><span class="lang-jp">発生日</span></th>
                                <th><span class="lang-vi">Nhóm</span><span class="lang-jp">チーム</span></th>
                                <th><span class="lang-vi">Model</span><span class="lang-jp">機種</span></th>
                                <th><span class="lang-vi">Hiện tượng</span><span class="lang-jp">現象</span></th>
                                <th><span class="lang-vi">Nguyên nhân</span><span class="lang-jp">原因</span></th>
                                <th><span class="lang-vi">Người cập nhật</span><span class="lang-jp">更新者</span></th>
                                <th><span class="lang-vi">Thao tác</span><span class="lang-jp">操作</span></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                string badgeClass = "badge-open";
                                if (item.Status != null)
                                {
                                    if (item.Status.Contains("Close"))
                                    {
                                        badgeClass = "badge-close";
                                    }
                                    else if (item.Status.Contains("調査中") || item.Status.Contains("Đang"))
                                    {
                                        badgeClass = "badge-investigating";
                                    }
                                    else if (item.Status.Contains("対策"))
                                    {
                                        badgeClass = "badge-countermeasure";
                                    }
                                }
                                <tr>
                                    <td><a href="@Url.Action("Details", new { id = item.Id })" style="color:#1565c0; font-weight:700;">@(string.IsNullOrWhiteSpace(item.ManagementNumber) ? item.Id.ToString() : item.ManagementNumber)</a></td>
                                    <td>@item.Factory</td>
                                    <td><span class="badge-status @badgeClass">@item.Status</span></td>
                                    <td>@item.OccurrencePeriod</td>
                                    <td>@item.Team</td>
                                    <td><strong>@item.Model</strong></td>
                                    <td>@item.Phenomenon</td>
                                    <td>@item.CauseClassification</td>
                                    <td>@item.UpdatedBy</td>
                                    <td style="text-align:center; white-space:nowrap;">
                                        <a href="@Url.Action("Edit", new { id = item.Id })" class="btn-iss btn-iss-warning" style="padding:3px 8px; font-size:11px; text-decoration:none;">&#9998; <span class="lang-vi">Sửa</span><span class="lang-jp">編集</span></a>
                                        <a href="@Url.Action("Details", new { id = item.Id })" class="btn-iss btn-iss-primary" style="padding:3px 8px; font-size:11px; text-decoration:none;">&#128065; <span class="lang-vi">Xem</span><span class="lang-jp">詳細</span></a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div style="padding:30px; text-align:center; color:#90a4ae;">
                    <span style="font-size:40px;">&#128270;</span>
                    <p style="margin-top:10px;"><span class="lang-vi">Không tìm thấy kết quả phù hợp.</span><span class="lang-jp">該当する結果が見つかりませんでした。</span></p>
                </div>
            }
        </div>
    </div>
}
